<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke Test Suite" parallel="classes" thread-count="4">
    <test name="API Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.automationexercise.qe.api.tests.smoke.AuthApiSmokeTests"/>
            <class name="com.automationexercise.qe.api.tests.smoke.ProductsApiSmokeTests"/>
        </classes>
    </test>
    
    <test name="UI Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.automationexercise.qe.ui.tests.smoke.AuthSmokeTests"/>
            <class name="com.automationexercise.qe.ui.tests.smoke.ProductsSmokeTests"/>
        </classes>
    </test>
</suite>
